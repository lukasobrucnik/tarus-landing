# Contact form email delivery (required for /api/contact to send emails)
# Copy this file to .env.local and fill in your values.

# From https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Sandbox mode (no verified domain yet): Resend only delivers to the email
# address registered on your Resend account. Once tarus.cz is verified as a
# domain in Resend, switch this to the real inbox (e.g. obchod@tarus.cz).
CONTACT_TO=your-resend-account-email@example.com

# Sandbox mode: must stay onboarding@resend.dev until a domain is verified.
# After domain verification, switch to e.g. "TARUS Web <noreply@tarus.cz>".
CONTACT_FROM=TARUS Web <onboarding@resend.dev>
